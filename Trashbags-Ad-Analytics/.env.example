# -----------------------------------------------
# DEMO MODE CONTROL
# -----------------------------------------------
# Set DEMO_MODE=true to run with fake data (no APIs needed)
# Set DEMO_MODE=false to run with real APIs
DEMO_MODE=true

# -----------------------------------------------
# META MARKETING API
# How to get: https://developers.facebook.com/docs/marketing-apis
# Requires: ads_read permission + Business Manager access
# Steps:
#   1. Go to https://developers.facebook.com and create an app
#   2. Add Marketing API product
#   3. Generate a User Access Token with ads_read scope
#   4. Find your Ad Account ID in Business Manager > Ad Accounts
# -----------------------------------------------
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=your_ad_account_id_here

# -----------------------------------------------
# META AD LIBRARY API
# How to get: https://www.facebook.com/ads/library/api
# Steps:
#   1. Visit the URL above and register your Facebook developer app
#   2. Generate a token with ads_read scope
#   3. No Business Manager required — public data
# -----------------------------------------------
META_AD_LIBRARY_TOKEN=your_ad_library_token_here

# -----------------------------------------------
# GOOGLE TRENDS
# No API key required — uses the pytrends library
# pytrends wraps the unofficial Google Trends endpoint
# -----------------------------------------------
GOOGLE_TRENDS_GEO=worldwide

# -----------------------------------------------
# OPENSNOW API
# How to get: https://opensnow.com/api
# Contact OpenSnow directly for API access
# -----------------------------------------------
OPENSNOW_API_KEY=your_opensnow_api_key_here

# -----------------------------------------------
# WEATHER API (Tomorrow.io)
# How to get: https://www.tomorrow.io/weather-api
# Steps:
#   1. Sign up at tomorrow.io (free tier available)
#   2. Copy your API key from the dashboard
# -----------------------------------------------
WEATHER_API_KEY=your_weather_api_key_here

# -----------------------------------------------
# ANTHROPIC API
# How to get: https://console.anthropic.com
# Steps:
#   1. Sign up / log in at console.anthropic.com
#   2. Go to API Keys and create a new key
# -----------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------
# GMAIL
# How to get: https://developers.google.com/gmail/api/quickstart/python
# Steps:
#   1. Go to Google Cloud Console and create a project
#   2. Enable the Gmail API
#   3. Create OAuth2 credentials (Desktop app type)
#   4. Download the JSON file and save to credentials/gmail_credentials.json
#   5. First run will open a browser for OAuth consent
# -----------------------------------------------
GMAIL_RECIPIENT=businessowner@gmail.com
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json

# -----------------------------------------------
# SCHEDULER
# Day and time to send weekly report (local machine time)
# Valid days: monday, tuesday, wednesday, thursday, friday, saturday, sunday
# -----------------------------------------------
SCHEDULE_DAY=sunday
SCHEDULE_TIME=08:00
