# Copy this file to ".env" and fill in real values. .env is gitignored.

# --- Meta / Instagram (Requirement 1 & 4) ---
ACTIVE_APP=primary
IG_VERIFY_TOKEN=pick-any-random-string-and-paste-the-same-one-in-meta
IG_APP_SECRET=
IG_ACCESS_TOKEN=
# Backup app — fill in once you've created a second Meta app (Requirement 1)
IG_BACKUP_APP_SECRET=
IG_BACKUP_ACCESS_TOKEN=
GRAPH_API_VERSION=v21.0

# --- The AI (Requirement 3) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_TIMEOUT_SECONDS=8
CONFIDENCE_THRESHOLD=0.6

# Random human-like delay before an auto-reply, in minutes (avoids instant-bot feel).
# Applies to live replies; /simulate just reports the delay instead of waiting.
RESPONSE_DELAY_MIN_MINUTES=10
RESPONSE_DELAY_MAX_MINUTES=30

# --- Human takeover (Requirement 5) ---
# Comma-separated; any of these words in a customer message flags it for the owner.
# Brand rule: only affiliate/sponsorship inquiries go to a human (backup net for the AI).
TAKEOVER_KEYWORDS=affiliate,sponsor,sponsorship,sponsored,collab,collaboration,ambassador,team rider

# --- Alerts (Requirements 5 & 7) ---
NOTIFY_CHANNEL=console
OWNER_NAME=your friend
# For Slack alerts: set NOTIFY_CHANNEL=slack and paste an Incoming Webhook URL
SLACK_WEBHOOK_URL=
# For SMS alerts: set NOTIFY_CHANNEL=twilio and fill these in
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_PHONE_NUMBER=

# --- Storage (Requirement 6) ---
DATABASE_PATH=data/automation.db
